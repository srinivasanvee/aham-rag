{
  "name": "aham-rag",
  "version": "0.1.0",
  "description": "Offline RAG desktop app powered by Ollama and Gemma 3",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "predev": "electron-rebuild -f -w better-sqlite3",
    "prebuild": "electron-rebuild -f -w better-sqlite3",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.13.0",
    "apache-arrow": "^17.0.0",
    "better-sqlite3": "^11.5.0",
    "electron-log": "^5.2.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "lucide-react": "^0.454.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-dropzone": "^14.3.0",
    "react-markdown": "^9.0.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9",
    "zustand": "^5.0.0"
  }
}
